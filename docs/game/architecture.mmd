%% Game runtime lifecycle architecture
%% Maintained manually; reflects current create/init/join/start/end/clean flow.
flowchart TD
    C0[Command: /myulib:game create] --> C1[GameManager.createInstance]
    C1 --> C2[GameDefinition.createInstance]
    C2 --> C3[createStateMachine + createEventBus]
    C3 --> C4[new GameInstance]
    C4 --> C5[GameScopeTokens.scoped]
    C5 --> C6[GameInstance.setupIdentity]

    I0[Command: /myulib:game init] --> I1[GameManager.initInstance]
    I1 --> I2[GameInstance.init]
    I2 --> I3[GameConfig.validate (manager checks)]
    I3 --> I4[GameDefinition.createInitialData]
    I4 --> I5[GameData.init (rollback)]
    I5 --> I6[initializeRuntimeObjects]
    I6 --> I7[GameDefinition.init -> bindBehavior]
    I7 --> I8[initialized = true]

    J0[Command: /myulib:game join] --> J1[GameManager.joinPlayer]
    J1 --> J2{enabled and initialized?}
    J2 -- no --> J3[join failed]
    J2 -- yes --> J4[GameInstance.joinPlayer]
    J4 --> J5[resolveTeamForJoin + movePlayerToTeam]
    J5 --> J6[playerToInstanceMap update]

    S0[Command: /myulib:game start] --> S1[GameManager.startInstance]
    S1 --> S2{enabled and initialized?}
    S2 -- no --> S3[start failed]
    S2 -- yes --> S4[GameInstance.start]
    S4 --> S5[GameDefinition.onStart]
    S5 --> S6[started = true]

    E0[Command: /myulib:game end] --> E1[GameManager.shutdownInstance]
    E1 --> E2[GameInstance.shutdown]
    E2 --> E3[GameDefinition.onShutDown]
    E3 --> E4[GameInstance.clean]
    E4 --> E5[cleanupRuntimeResources]
    E5 --> E6[definition.clean + eventBus.clear + data.reset]
    E6 --> E7[initialized = false, started = false]
    E7 --> E8[unassignPlayersInInstance]

    D0[Command: /myulib:game delete] --> D1[GameManager.destroyInstance]
    D1 --> D2[GameInstance.destroy]
    D2 --> D3[clean + enabled = false + remove maps]
