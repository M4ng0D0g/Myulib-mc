graph TB
    subgraph EventCore["Event Core System"]
        Event["Event (Abstract)<br/>+ source: Object<br/>+ canceled: boolean<br/>+ setCanceled(boolean)"]

        FailableEvent["FailableEvent (Abstract)<br/>extends Event<br/>+ failureReason: String<br/>+ fail(String)"]

        ProcessResult["ProcessResult (Enum)<br/>PASS, CONSUME"]

        EventPriority["EventPriority (Enum)<br/>LOWEST, LOW, NORMAL, HIGH, HIGHEST"]

        EventListener["EventListener<T><br/>+ onEvent(T): ProcessResult"]

        ServerEventBus["ServerEventBus (Singleton)<br/>- listeners: Map<Class, List><br/>+ subscribe(Class, EventListener)<br/>+ unsubscribe(Class, EventListener)<br/>+ dispatch(Event)"]
    end

    subgraph ObjectEvents["Object Events"]
        BlockBreakEvent["BlockBreakEvent extends Event<br/>+ pos: BlockPos<br/>+ player: ServerPlayer<br/>+ level: ServerLevel"]

        BlockInteractEvent["BlockInteractEvent extends Event<br/>+ pos: BlockPos<br/>+ player: ServerPlayer<br/>+ level: ServerLevel"]

        EntityDamageEvent["EntityDamageEvent extends Event<br/>+ victim: Entity<br/>+ source: DamageSource<br/>+ amount: float"]

        EntityDeathEvent["EntityDeathEvent extends Event<br/>+ victim: Entity<br/>+ source: DamageSource"]

        EntityInteractEvent["EntityInteractEvent extends Event<br/>+ entity: Entity<br/>+ player: ServerPlayer"]

        ObjectMineEvent["ObjectMineEvent extends Event<br/>+ object: IObjectRt<br/>+ player: ServerPlayer"]

        ObjectInteractEvent["ObjectInteractEvent extends Event<br/>+ object: IObjectRt<br/>+ player: ServerPlayer"]

        ObjectDamageEvent["ObjectDamageEvent extends Event<br/>+ object: IObjectRt<br/>+ source: DamageSource<br/>+ amount: float"]

        ObjectDeathEvent["ObjectDeathEvent extends Event<br/>+ object: IObjectRt<br/>+ source: DamageSource"]

        StateChangeEvent["StateChangeEvent extends Event<br/>+ oldState: Object<br/>+ newState: Object"]
    end

    subgraph ListenerSystem["Listener System"]
        EventListenerRegistry["EventListenerRegistry<br/>- registry: Map<Class, Set<EventListener>><br/>+ register(Class, EventListener)<br/>+ unregister(Class, EventListener)<br/>+ getListeners(Class)"]

        ListenerRegistry["ListenerRegistry<br/>+ register(EventListener)<br/>+ unregister(EventListener)"]
    end

    subgraph OtherSystems["System Integration"]
        TimerEventListeners["TimerEventListeners<br/>- listens to game events<br/>- triggers timer updates"]

        PermissionEventListeners["PermissionEventListeners<br/>- tracks permission-related events"]

        GameEventListeners["GameEventListeners<br/>- listens to object/state changes"]
    end

    %% Core relationships
    Event -->|base for| FailableEvent
    Event -->|base for| BlockBreakEvent
    Event -->|base for| BlockInteractEvent
    Event -->|base for| EntityDamageEvent
    Event -->|base for| EntityDeathEvent
    Event -->|base for| EntityInteractEvent
    Event -->|base for| ObjectMineEvent
    Event -->|base for| ObjectInteractEvent
    Event -->|base for| ObjectDamageEvent
    Event -->|base for| ObjectDeathEvent
    Event -->|base for| StateChangeEvent

    ServerEventBus -->|manages| EventListener
    ServerEventBus -->|dispatches| Event
    EventListener -->|processes| ProcessResult
    EventPriority -->|influences| ServerEventBus

    %% Object event hierarchy
    BlockBreakEvent -->|triggered by| MineableBeh
    BlockInteractEvent -->|triggered by| InteractableBeh
    EntityDamageEvent -->|triggered by| AttackableBeh
    EntityDeathEvent -->|triggered by| AttackableBeh

    ObjectMineEvent -->|dispatched by| MineableBeh
    ObjectInteractEvent -->|dispatched by| InteractableBeh
    ObjectDamageEvent -->|dispatched by| AttackableBeh
    ObjectDeathEvent -->|dispatched by| AttackableBeh

    %% System integration
    ServerEventBus -->|used by| TimerEventListeners
    ServerEventBus -->|used by| PermissionEventListeners
    ServerEventBus -->|used by| GameEventListeners

    %% EventListenerRegistry relationships
    EventListenerRegistry -->|manages| EventListener
    EventListenerRegistry -.->|alternative to| ServerEventBus

    style EventCore fill:#e3f2fd
    style ObjectEvents fill:#f3e5f5
    style ListenerSystem fill:#fff3e0
    style OtherSystems fill:#f1f8e9

