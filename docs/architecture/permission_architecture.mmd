graph TB
    subgraph PermissionCore["Permission Core"]
        PermissionAction["PermissionAction<br/>+ resource: String (e.g., 'team.admin')<br/>+ action: String (e.g., 'create', 'modify')<br/>+ scope: PermissionScope"]

        PermissionDecision["PermissionDecision (Enum)<br/>ALLOW, DENY, DEFAULT"]

        PermissionScope["PermissionScope (Enum)<br/>GLOBAL, TEAM, FIELD, GAME"]

        ScopeLayer["ScopeLayer<br/>- scope: PermissionScope<br/>- scopeId: Identifier (optional)<br/>- permissions: Map<PermissionAction, Decision>"]

        PermissionTable["PermissionTable<br/>- layers: List<ScopeLayer><br/>+ check(PermissionAction): PermissionDecision<br/>+ addLayer(ScopeLayer)<br/>+ removeLayer(ScopeLayer)"]

        PermissionManager["PermissionManager (Singleton)<br/>- tables: Map<UUID, PermissionTable><br/>+ getTable(UUID): PermissionTable<br/>+ check(UUID, PermissionAction): boolean<br/>+ grant(UUID, PermissionAction)<br/>+ revoke(UUID, PermissionAction)"]
    end

    subgraph PermissionGate["Permission Gate"]
        PermissionGate["PermissionGate<br/>+ check(player, action): boolean<br/>+ check(player, resource, action): boolean<br/>+ requirePermission(player, action): void<br/>- throws: PermissionException"]
    end

    subgraph PermissionStorage["Permission Storage"]
        PermissionStorageInterface["PermissionStorage (Interface)<br/>+ save(UUID, PermissionTable)<br/>+ load(UUID): PermissionTable<br/>+ delete(UUID)<br/>+ getAll(): Map"]

        PermissionStorageImpl["PermissionStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize tables"]
    end

    subgraph RoleGroupIntegration["RoleGroup Integration"]
        RoleGroupDefinition["RoleGroupDefinition<br/>+ permissions: Set<PermissionAction><br/>- members: Set<UUID>"]

        RoleGroupManager["RoleGroupManager<br/>+ grants default permissions<br/>+ manages group membership"]
    end

    subgraph CommandIntegration["Command System Integration"]
        AccessCommandService["AccessCommandService<br/>+ permission checks on all commands<br/>+ grant/revoke permission commands"]

        CommandRegistry["CommandRegistry<br/>+ REQUIRE_PERMISSION annotation<br/>+ validates permission before execution"]
    end

    subgraph PredefinedPermissions["Predefined Permissions"]
        TeamPermissions["Team Permissions<br/>- team.view<br/>- team.admin.create<br/>- team.admin.modify<br/>- team.admin.delete"]

        FieldPermissions["Field Permissions<br/>- field.view<br/>- field.admin.create<br/>- field.admin.modify<br/>- field.admin.delete"]

        GamePermissions["Game Permissions<br/>- game.admin<br/>- game.create<br/>- game.start<br/>- game.stop"]

        RoleGroupPermissions["RoleGroup Permissions<br/>- rolegroup.admin.create<br/>- rolegroup.admin.modify<br/>- rolegroup.admin.delete"]
    end

    %% Core relationships
    PermissionAction -->|decision| PermissionDecision
    PermissionAction -->|scope| PermissionScope
    ScopeLayer -->|contains| PermissionAction
    PermissionTable -->|manages| ScopeLayer
    PermissionManager -->|manages| PermissionTable
    PermissionGate -->|uses| PermissionManager

    %% Storage
    PermissionManager -->|persists via| PermissionStorageInterface
    PermissionStorageInterface -->|implemented by| PermissionStorageImpl

    %% RoleGroup integration
    RoleGroupManager -->|grants| PermissionAction
    RoleGroupDefinition -->|grants to members| PermissionAction
    RoleGroupManager -->|registers in| PermissionManager

    %% Command integration
    AccessCommandService -->|checks| PermissionGate
    CommandRegistry -->|enforces| PermissionGate

    %% Predefined permissions
    TeamPermissions -->|used by| PermissionManager
    FieldPermissions -->|used by| PermissionManager
    GamePermissions -->|used by| PermissionManager
    RoleGroupPermissions -->|used by| PermissionManager

    %% System flow
    AccessCommandService -->|checks permission| PermissionGate
    PermissionGate -->|queries| PermissionManager
    PermissionManager -->|retrieves| PermissionTable
    PermissionTable -->|evaluates| ScopeLayer

    style PermissionCore fill:#e1f5fe
    style PermissionGate fill:#fff3e0
    style PermissionStorage fill:#f3e5f5
    style RoleGroupIntegration fill:#e8f5e9
    style CommandIntegration fill:#fce4ec
    style PredefinedPermissions fill:#e0f2f1

