graph TB
    subgraph HologramCore["Hologram Core"]
        HologramDefinition["HologramDefinition (Record)<br/>- token: String<br/>- dimensionId: Identifier<br/>- bounds: AABB<br/>- label: String<br/>- style: HologramStyle<br/>+ toIdentifier(): Identifier"]

        HologramStyle["HologramStyle (Record)<br/>- color: int<br/>- scale: float<br/>- transparency: float<br/>- showLabel: boolean<br/>- animationMode: AnimationMode"]

        HologramFeature["HologramFeature (Enum)<br/>DISPLAY_ENTITY, ARMOR_STAND<br/>ITEM_DISPLAY, TEXT_DISPLAY"]

        HologramManager["HologramManager (Singleton)<br/>- holograms: Map<Identifier, HologramDefinition><br/>+ register(HologramDefinition)<br/>+ unregister(Identifier)<br/>+ all(): Map<Identifier, HologramDefinition><br/>+ validate(HologramDefinition): boolean"]
    end

    subgraph HologramRuntime["Hologram Runtime"]
        HologramObject["HologramObject (Runtime)<br/>- definition: HologramDefinition<br/>- entity: DisplayEntity<br/>- position: Vec3<br/>+ updatePosition(Vec3)<br/>+ updateText(String)<br/>+ updateStyle(HologramStyle)<br/>+ remove()"]

        HologramDisplay["HologramDisplay<br/>- hologram: HologramObject<br/>- visibleTo: Set<ServerPlayer><br/>- culling: BoundingBox<br/>+ updateVisibility(Player)<br/>+ sendPacket(Player)"]
    end

    subgraph HologramStorage["Hologram Storage"]
        HologramStorageInterface["HologramStorage (Interface)<br/>+ save(Identifier, HologramDefinition)<br/>+ load(Identifier): HologramDefinition<br/>+ delete(Identifier)<br/>+ listAll(): Collection"]

        HologramStorageImpl["HologramStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize<br/>+ coordinate validation"]
    end

    subgraph HologramNetwork["Network & Display"]
        HologramNetworkPacket["HologramNetworkPacket<br/>+ hologramId: Identifier<br/>+ position: Vec3<br/>+ text: String<br/>+ style: HologramStyle<br/>+ action: Action"]

        HologramNetworkHandler["HologramNetworkHandler<br/>+ sendHologramCreate(Player, HologramDefinition)<br/>+ sendHologramUpdate(Player, Identifier, Update)<br/>+ sendHologramRemove(Player, Identifier)"]
    end

    subgraph Integration["System Integration"]
        GameConfig["GameConfig<br/>- can define field holograms"]

        GameData["GameData<br/>- renders holograms in field"]

        AccessCommandService["AccessCommandService<br/>+ createHologramCommand<br/>+ modifyHologramCommand<br/>+ deleteHologramCommand"]

        FieldManager["FieldManager<br/>- associate holograms with fields"]

        PermissionManager["PermissionManager<br/>+ hologram.admin permissions"]

        AnimationSystem["Animation System<br/>+ animate hologram position<br/>+ animate hologram text<br/>+ animate hologram color"]
    end

    %% Core relationships
    HologramDefinition -->|uses| HologramStyle
    HologramDefinition -->|uses| HologramFeature
    HologramManager -->|manages| HologramDefinition
    HologramManager -->|persists via| HologramStorageInterface
    HologramStorageInterface -->|implemented by| HologramStorageImpl

    %% Runtime
    HologramObject -->|created from| HologramDefinition
    HologramDisplay -->|displays| HologramObject
    HologramObject -->|renders as| HologramFeature

    %% Network
    HologramNetworkHandler -->|sends| HologramNetworkPacket
    HologramObject -->|updates via| HologramNetworkHandler

    %% Integration
    GameConfig -->|may reference| HologramDefinition
    GameData -->|instantiates| HologramObject
    AccessCommandService -->|manages| HologramManager
    FieldManager -->|contains| HologramDefinition
    PermissionManager -->|controls| AccessCommandService
    AnimationSystem -->|animates| HologramObject

    %% Visibility culling
    HologramDisplay -->|culls by bounds| HologramDefinition
    HologramDisplay -->|tracks visibility per| ServerPlayer

    style HologramCore fill:#e1f5fe
    style HologramRuntime fill:#e8f5e9
    style HologramStorage fill:#f3e5f5
    style HologramNetwork fill:#fff3e0
    style Integration fill:#fce4ec

