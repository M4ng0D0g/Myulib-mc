graph TB
    subgraph EventCore["Event Core"]
        Event["Event (Base)<br/>- source: Object<br/>- canceled: boolean<br/>+ setCanceled(boolean)"]

        FailableEvent["FailableEvent<br/>extends Event<br/>- failureReason: String<br/>+ fail(String)"]
    end

    subgraph BlockEventHierarchy["Block Event Hierarchy"]
        BlockBreakEvent["BlockBreakEvent extends Event<br/>- pos: BlockPos<br/>- player: ServerPlayer<br/>- level: ServerLevel<br/>- fired by: MineableBeh listener"]

        BlockInteractEvent["BlockInteractEvent extends Event<br/>- pos: BlockPos<br/>- player: ServerPlayer<br/>- level: ServerLevel<br/>- fired by: InteractableBeh listener"]
    end

    subgraph EntityEventHierarchy["Entity Event Hierarchy"]
        EntityDamageEvent["EntityDamageEvent extends Event<br/>- victim: Entity<br/>- source: DamageSource<br/>- amount: float<br/>- fired by: AttackableBeh listener"]

        EntityDeathEvent["EntityDeathEvent extends Event<br/>- victim: Entity<br/>- source: DamageSource<br/>- fired by: AttackableBeh listener"]

        EntityInteractEvent["EntityInteractEvent extends Event<br/>- entity: Entity<br/>- player: ServerPlayer<br/>- fired by: user interaction"]
    end

    subgraph ObjectEventHierarchy["Object Event Hierarchy"]
        ObjectMineEvent["ObjectMineEvent extends Event<br/>- object: IObjectRt<br/>- player: ServerPlayer<br/>+ created by: MineableBeh<br/>+ type: custom game event"]

        ObjectInteractEvent["ObjectInteractEvent extends Event<br/>- object: IObjectRt<br/>- player: ServerPlayer<br/>+ created by: InteractableBeh<br/>+ type: custom game event"]

        ObjectDamageEvent["ObjectDamageEvent extends Event<br/>- object: IObjectRt<br/>- source: DamageSource<br/>- amount: float<br/>+ created by: AttackableBeh"]

        ObjectDeathEvent["ObjectDeathEvent extends Event<br/>- object: IObjectRt<br/>- source: DamageSource<br/>+ created by: AttackableBeh"]
    end

    subgraph StateChangeEvent["State Events"]
        StateChangeEvent["StateChangeEvent extends Event<br/>- oldState: Object<br/>- newState: Object<br/>+ fired by: GameStateMachine<br/>+ fired by: GameData"]
    end

    subgraph EventEmitterMapping["Event Emitter Mapping"]
        MineableBehEmitter["MineableBeh<br/>+ subscribes: BlockBreakEvent<br/>+ emits: ObjectMineEvent<br/>+ condition: block broken<br/>+ location: object bounds"]

        InteractableBehEmitter["InteractableBeh<br/>+ subscribes: BlockInteractEvent<br/>+ emits: ObjectInteractEvent<br/>+ condition: right-click<br/>+ cooldown check"]

        AttackableBehEmitter["AttackableBeh<br/>+ subscribes: EntityDamageEvent<br/>+ subscribes: EntityDeathEvent<br/>+ emits: ObjectDamageEvent<br/>+ emits: ObjectDeathEvent<br/>+ condition: victim UUID match"]
    end

    subgraph EventProcessing["Event Processing"]
        EventCapture["Event Capture<br/>+ Minecraft event fires<br/>+ MyuLib mixin intercepts<br/>+ delegates to behavior"]

        BehaviorFilter["Behavior Filtering<br/>+ check if event applies<br/>+ validate conditions<br/>+ check cooldowns"]

        ObjectEventCreation["Object Event Creation<br/>+ create event instance<br/>+ copy relevant data<br/>+ set source to object"]

        EventDispatch["Event Dispatch<br/>+ add to event queue<br/>+ send to ServerEventBus<br/>+ broadcast to listeners"]
    end

    subgraph EventBusIntegration["Event Bus Integration"]
        ServerEventBus["ServerEventBus<br/>- listens to all events<br/>- maintains listener list<br/>- dispatch() broadcasts"]

        EventListener["EventListener<E><br/>+ onEvent(E): ProcessResult"]

        ProcessResult["ProcessResult<br/>PASS - continue<br/>CONSUME - handled"]
    end

    subgraph ListenerPattern["Listener Pattern"]
        BehaviorAsListener["Behavior as Listener<br/>+ IObjectBeh extends EventListener<br/>+ onInitialize: subscribe<br/>+ onDestroy: unsubscribe<br/>+ onEvent: filter & emit"]

        ListenerRegistration["Registration<br/>+ bus.subscribe(Class, listener)<br/>+ listener stored in map<br/>+ key: event class"]

        ListenerInvocation["Invocation<br/>+ dispatch(event)<br/>+ lookup listeners for type<br/>+ call onEvent()<br/>+ collect results"]
    end

    %% Core relationships
    Event -->|extended by| FailableEvent
    Event -->|extended by| BlockBreakEvent
    Event -->|extended by| BlockInteractEvent
    Event -->|extended by| EntityDamageEvent
    Event -->|extended by| EntityDeathEvent
    Event -->|extended by| EntityInteractEvent
    Event -->|extended by| ObjectMineEvent
    Event -->|extended by| ObjectInteractEvent
    Event -->|extended by| ObjectDamageEvent
    Event -->|extended by| ObjectDeathEvent
    Event -->|extended by| StateChangeEvent

    %% Emitter mapping
    MineableBeh -->|subscribes to| BlockBreakEvent
    MineableBeh -->|emits| ObjectMineEvent
    InteractableBeh -->|subscribes to| BlockInteractEvent
    InteractableBeh -->|emits| ObjectInteractEvent
    AttackableBeh -->|subscribes to| EntityDamageEvent
    AttackableBeh -->|subscribes to| EntityDeathEvent
    AttackableBeh -->|emits| ObjectDamageEvent
    AttackableBeh -->|emits| ObjectDeathEvent

    %% Event processing
    EventCapture -->|leads to| BehaviorFilter
    BehaviorFilter -->|leads to| ObjectEventCreation
    ObjectEventCreation -->|leads to| EventDispatch

    %% Bus integration
    EventDispatch -->|sends to| ServerEventBus
    ServerEventBus -->|calls| EventListener
    EventListener -->|returns| ProcessResult

    %% Listener pattern
    MineableBehEmitter -->|implements| BehaviorAsListener
    InteractableBehEmitter -->|implements| BehaviorAsListener
    AttackableBehEmitter -->|implements| BehaviorAsListener
    BehaviorAsListener -->|uses| ListenerRegistration
    ListenerRegistration -->|uses| ListenerInvocation

    %% Data flow
    BlockBreakEvent -->|-> ObjectMineEvent<br/>via MineableBeh| ObjectMineEvent
    BlockInteractEvent -->|-> ObjectInteractEvent<br/>via InteractableBeh| ObjectInteractEvent
    EntityDamageEvent -->|-> ObjectDamageEvent<br/>via AttackableBeh| ObjectDamageEvent
    EntityDeathEvent -->|-> ObjectDeathEvent<br/>via AttackableBeh| ObjectDeathEvent

