graph TB
    subgraph CommandCore["Command Core"]
        CommandRegistry["CommandRegistry (Singleton)<br/>- commands: Map<String, CommandAction><br/>+ register(CommandAction)<br/>+ unregister(String)<br/>+ execute(String, CommandContext)<br/>+ getCompletions(String): List"]

        CommandAction["CommandAction (Interface)<br/>+ execute(CommandContext): CommandResult<br/>+ getCompletions(CommandContext): List<String>"]

        CommandContext["CommandContext<br/>- player: ServerPlayer<br/>- args: String[]<br/>- currentTeam: Identifier<br/>- currentField: Identifier<br/>+ getPlayer(), getArgs()<br/>+ getCurrentTeam(), getCurrentField()"]

        CommandResult["CommandResult (Record)<br/>- success: boolean<br/>- message: String<br/>+ status: CommandStatus"]
    end

    subgraph AccessCommands["Access Command Service"]
        AccessCommandService["AccessCommandService (Singleton)<br/>- commandRegistry: CommandRegistry<br/>+ registerFieldCommands()<br/>+ registerTeamCommands()<br/>+ registerGameCommands()<br/>+ registerPermissionCommands()"]

        FieldCommands["Field Commands<br/>- /field create<br/>- /field list<br/>- /field modify<br/>- /field delete<br/>- /field visualize"]

        TeamCommands["Team Commands<br/>- /team create<br/>- /team list<br/>- /team modify<br/>- /team delete"]

        RoleGroupCommands["RoleGroup Commands<br/>- /rolegroup create<br/>- /rolegroup member add<br/>- /rolegroup member remove<br/>- /rolegroup delete"]

        GameCommands["Game Commands<br/>- /game start<br/>- /game stop<br/>- /game config<br/>- /game join<br/>- /game leave"]

        PermissionCommands["Permission Commands<br/>- /permission grant<br/>- /permission revoke<br/>- /permission check"]
    end

    subgraph CommandParsing["Command Parsing & Validation"]
        CommandParser["CommandParser<br/>+ parseArguments(String[]): Map<String, Object><br/>+ validateArguments(Map): boolean"]

        ArgumentValidator["ArgumentValidator<br/>+ validateIdentifier(String)<br/>+ validateUUID(String)<br/>+ validateInteger(String)<br/>+ validatePath(String)"]

        CompletionProvider["CompletionProvider<br/>+ fieldIdSuggestions(): List<String><br/>+ teamIdSuggestions(): List<String><br/>+ playerNameSuggestions(): List<String>"]
    end

    subgraph PermissionIntegration["Permission Integration"]
        PermissionGate["PermissionGate<br/>- checks player permissions<br/>- throws PermissionException"]

        PermissionCheckDecorator["@RequirePermission Annotation<br/>+ permission: PermissionAction<br/>+ scope: PermissionScope"]
    end

    subgraph FeedbackSystem["Feedback System"]
        CommandFeedback["CommandFeedback<br/>+ sendSuccess(Player, String)<br/>+ sendError(Player, String)<br/>+ sendInfo(Player, String)"]

        NotificationManager["NotificationManager<br/>- broadcasts command results<br/>- action logs"]
    end

    subgraph Integration["System Integration"]
        FieldManager["FieldManager<br/>+ provides field data<br/>+ validates field operations"]

        TeamManager["TeamManager<br/>+ provides team data<br/>+ validates team operations"]

        RoleGroupManager["RoleGroupManager<br/>+ provides group data<br/>+ manages membership"]

        GameManager["GameManager<br/>+ provides game instances<br/>+ validates game operations"]

        PermissionManager["PermissionManager<br/>+ gate: PermissionGate<br/>+ grant/revoke permissions"]

        ServerEventBus["ServerEventBus<br/>+ broadcasts command events<br/>+ notifies listeners"]
    end

    %% Core relationships
    CommandRegistry -->|manages| CommandAction
    CommandRegistry -->|uses| CommandContext
    CommandRegistry -->|parses| CommandParser
    CommandParser -->|validates| ArgumentValidator

    %% Access Command Service
    AccessCommandService -->|registers| FieldCommands
    AccessCommandService -->|registers| TeamCommands
    AccessCommandService -->|registers| RoleGroupCommands
    AccessCommandService -->|registers| GameCommands
    AccessCommandService -->|registers| PermissionCommands
    AccessCommandService -->|uses| CommandRegistry

    %% Command implementations
    FieldCommands -->|implements| CommandAction
    TeamCommands -->|implements| CommandAction
    RoleGroupCommands -->|implements| CommandAction
    GameCommands -->|implements| CommandAction
    PermissionCommands -->|implements| CommandAction

    %% Parsing & Validation
    CommandRegistry -->|uses| CompletionProvider
    CompletionProvider -->|provides| FieldManager
    CompletionProvider -->|provides| TeamManager
    CompletionProvider -->|provides| RoleGroupManager

    %% Permission
    CommandAction -->|checks| PermissionGate
    PermissionGate -->|queries| PermissionManager
    PermissionManager -->|enforces| PermissionCheckDecorator

    %% Feedback
    CommandAction -->|sends| CommandFeedback
    CommandFeedback -->|notifies| ServerEventBus
    CommandAction -->|broadcasts| NotificationManager

    %% Integration
    FieldCommands -->|uses| FieldManager
    TeamCommands -->|uses| TeamManager
    RoleGroupCommands -->|uses| RoleGroupManager
    GameCommands -->|uses| GameManager
    PermissionCommands -->|uses| PermissionManager

