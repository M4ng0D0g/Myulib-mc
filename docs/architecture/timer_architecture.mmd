graph TB
    subgraph TimerCore["Timer Core"]
        TimerDefinition["TimerDefinition (Record)<br/>- token: String<br/>- duration: long (ticks)<br/>- mode: TimerMode<br/>- tickBasis: TimerTickBasis<br/>- payload: TimerPayload<br/>+ toIdentifier(): Identifier"]

        TimerMode["TimerMode (Enum)<br/>COUNTDOWN, STOPWATCH<br/>REPEATING"]

        TimerTickBasis["TimerTickBasis (Enum)<br/>GAME_TICK, REAL_TIME"]

        TimerStatus["TimerStatus (Enum)<br/>IDLE, RUNNING, PAUSED<br/>FINISHED, CANCELLED"]

        TimerPayload["TimerPayload (Interface)<br/>marker interface for custom data"]

        TimerManager["TimerManager (Singleton)<br/>- timers: Map<Identifier, TimerDefinition><br/>+ register(TimerDefinition)<br/>+ unregister(Identifier)<br/>+ all(): Collection<br/>+ validate(TimerDefinition): boolean"]
    end

    subgraph TimerRuntime["Timer Runtime"]
        TimerInstance["TimerInstance<br/>- definition: TimerDefinition<br/>- currentTime: long<br/>- status: TimerStatus<br/>- subscribers: List<TimerListener><br/>+ start(), pause(), resume()<br/>+ tick(deltaTime)<br/>+ getProgress(): double"]

        TimerBinding["TimerBinding<br/>- timers: Map<Identifier, TimerInstance><br/>+ bind(TimerDefinition): TimerInstance<br/>+ unbind(Identifier)<br/>+ tickAll(deltaTime)"]

        TimerSnapshot["TimerSnapshot<br/>- timerId: Identifier<br/>- status: TimerStatus<br/>- currentTime: long<br/>- progress: double<br/>+ toNetwork(): byte[]"]
    end

    subgraph TimerEvents["Timer Events"]
        TimerEvents["TimerEvents (Enum)<br/>START, TICK, PAUSE<br/>RESUME, FINISH, CANCEL"]

        TimerEventListener["TimerEventListener<br/>+ onTimerStart(TimerInstance)<br/>+ onTimerTick(TimerInstance, deltaTime)<br/>+ onTimerFinish(TimerInstance)"]
    end

    subgraph TimerAction["Timer Actions"]
        TimerAction["TimerAction (Interface)<br/>+ execute(TimerInstance)"]

        DelayedAction["DelayedAction<br/>- delay: long<br/>+ execute() after delay"]

        RepeatingAction["RepeatingAction<br/>- interval: long<br/>+ execute() every interval"]

        ConditionalAction["ConditionalAction<br/>- condition: Predicate<br/>+ execute() if condition met"]
    end

    subgraph TimerStorage["Timer Storage"]
        TimerStorageInterface["TimerStorage (Interface)<br/>+ save(Identifier, TimerDefinition)<br/>+ load(Identifier): TimerDefinition<br/>+ delete(Identifier)<br/>+ listAll(): Collection"]

        TimerStorageImpl["TimerStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize"]
    end

    subgraph Integration["System Integration"]
        GameConfig["GameConfig<br/>+ timerDefinitions(): List<TimerDefinition>"]

        GameData["GameData<br/>- timerBinding: TimerBinding<br/>+ initializeTimers()<br/>+ tickTimers()"]

        GameInstance["GameInstance<br/>+ getTimerBinding()<br/>+ tick()"]

        AccessCommandService["AccessCommandService<br/>+ createTimerCommand<br/>+ modifyTimerCommand<br/>+ startTimerCommand<br/>+ pauseTimerCommand"]

        ServerEventBus["ServerEventBus<br/>- listens to TimerEvents<br/>- broadcasts updates"]

        PermissionManager["PermissionManager<br/>+ timer.admin permissions"]
    end

    %% Core relationships
    TimerDefinition -->|uses| TimerMode
    TimerDefinition -->|uses| TimerTickBasis
    TimerDefinition -->|carries| TimerPayload
    TimerManager -->|manages| TimerDefinition
    TimerManager -->|persists via| TimerStorageInterface
    TimerStorageInterface -->|implemented by| TimerStorageImpl

    %% Runtime relationships
    TimerInstance -->|created from| TimerDefinition
    TimerInstance -->|has status| TimerStatus
    TimerInstance -->|fires| TimerEvents
    TimerBinding -->|manages| TimerInstance
    TimerInstance -->|creates| TimerSnapshot
    TimerInstance -->|attaches| TimerEventListener

    %% Action relationships
    TimerAction -->|executed by| TimerInstance
    DelayedAction -.->|implements| TimerAction
    RepeatingAction -.->|implements| TimerAction
    ConditionalAction -.->|implements| TimerAction
    TimerDefinition -->|carries| TimerAction

    %% Integration
    GameConfig -->|contains| TimerDefinition
    GameData -->|initializes| TimerBinding
    GameInstance -->|updates| TimerBinding
    TimerBinding -->|distributes updates| ServerEventBus
    AccessCommandService -->|manages| TimerManager
    ServerEventBus -->|listens to| TimerEvents
    PermissionManager -->|controls| AccessCommandService

    %% Event flow
    TimerInstance -->|emits| TimerEvents
    ServerEventBus -->|broadcasts| TimerEvents
    TimerEventListener -->|receives| TimerEvents

    style TimerCore fill:#fff3e0
    style TimerRuntime fill:#e3f2fd
    style TimerEvents fill:#f3e5f5
    style TimerAction fill:#e8f5e9
    style TimerStorage fill:#fce4ec
    style Integration fill:#f1f8e9

