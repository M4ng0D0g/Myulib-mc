graph TB
    subgraph AnimationCore["Animation Core"]
        AnimationSpec["AnimationSpec<br/>- name: String<br/>- duration: long (ticks)<br/>- keyframes: List<Keyframe><br/>- playMode: PlayMode"]

        PlayMode["PlayMode (Enum)<br/>ONCE, LOOP<br/>PING_PONG, REVERSE"]

        PlaybackState["PlaybackState<br/>- currentTime: long<br/>- status: PlayStatus<br/>- playMode: PlayMode<br/>+ play(), pause(), stop()"]

        Keyframe["Keyframe<br/>- time: long<br/>- value: Object<br/>- easing: Easing"]

        Easing["Easing (Interface)<br/>+ interpolate(progress): float<br/>+ getType(): EasingType"]

        AnimatorComponent["AnimatorComponent<br/>- currentAnimation: AnimationSpec<br/>- playback: PlaybackState<br/>- animations: Map<String, AnimationSpec>"]
    end

    subgraph Interpolation["Interpolation System"]
        ValueInterpolator["ValueInterpolator<br/>+ interpolate(from, to, progress): value<br/>+ interpolateVector(Vec3, Vec3, progress): Vec3<br/>+ interpolateRotation(Quat, Quat, progress): Quat"]

        Interpolators["Interpolators (Enum)<br/>LINEAR, CUBIC<br/>QUADRATIC, EXPONENTIAL"]

        AnimationTarget["AnimationTarget (Interface)<br/>+ applyValue(String, Object)<br/>+ getValue(String): Object"]
    end

    subgraph EasingFunctions["Easing Functions"]
        LinearEasing["LinearEasing<br/>+ y = x"]

        EaseInOut["EaseInOut (Cubic)<br/>+ acceleration & deceleration"]

        EaseIn["EaseIn<br/>+ slow start"]

        EaseOut["EaseOut<br/>+ slow end"]

        BounceEasing["BounceEasing<br/>+ bouncing effect"]

        BackEasing["BackEasing<br/>+ overshoot effect"]
    end

    subgraph AnimationPlayback["Animation Playback"]
        AnimationPlayer["AnimationPlayer<br/>- currentAnimation: AnimationSpec<br/>- playback: PlaybackState<br/>+ play(AnimationSpec)<br/>+ pause()<br/>+ resume()<br/>+ stop()"]

        AnimationScheduler["AnimationScheduler<br/>- animations: List<PlayingAnimation><br/>+ update(deltaTime)<br/>+ schedule(AnimationSpec, delay)"]

        PlayingAnimation["PlayingAnimation<br/>- spec: AnimationSpec<br/>- playback: PlaybackState<br/>- target: AnimationTarget<br/>+ tick(deltaTime)"]
    end

    subgraph Integration["System Integration"]
        AnimatorComponentComputed["AnimatorComponent<br/>+ tick(deltaTime)<br/>+ applyAnimations()"]

        EntityRender["Entity Rendering<br/>- uses animation targets<br/>- applies interpolated values"]

        GameInstance["GameInstance<br/>+ animationScheduler: AnimationScheduler<br/>+ tick()"]

        UISystem["UI System<br/>- animates UI elements<br/>- position, size, color"]

        ParticleSystem["Particle System<br/>- animates particles<br/>- position, velocity, color"]
    end

    %% Core relationships
    AnimationSpec -->|contains| Keyframe
    Keyframe -->|uses| Easing
    Easing -->|extends| LinearEasing
    Easing -->|extends| EaseInOut
    Easing -->|extends| EaseIn
    Easing -->|extends| EaseOut
    Easing -->|extends| BounceEasing
    Easing -->|extends| BackEasing

    AnimationSpec -->|uses| PlayMode
    PlaybackState -->|tracks| PlayMode
    AnimatorComponent -->|contains| AnimationSpec
    AnimatorComponent -->|contains| PlaybackState

    %% Interpolation
    AnimationPlayer -->|uses| ValueInterpolator
    ValueInterpolator -->|uses| Interpolators
    PlayingAnimation -->|applies to| AnimationTarget
    PlayingAnimation -->|uses| Easing

    %% Playback
    AnimationPlayer -->|manages| PlayingAnimation
    AnimationScheduler -->|manages| PlayingAnimation
    AnimationPlayer -->|uses| PlaybackState
    PlayingAnimation -->|updates| PlaybackState

    %% Integration
    AnimatorComponentComputed -->|plays| AnimationSpec
    AnimatorComponentComputed -->|uses| AnimationScheduler
    GameInstance -->|updates| AnimationScheduler
    EntityRender -->|applies| AnimationTarget
    AnimationScheduler -->|updates| PlayingAnimation
    PlayingAnimation -->|applies to| AnimationTarget

    %% Target types
    UISystem -->|implements| AnimationTarget
    ParticleSystem -->|implements| AnimationTarget
    EntityRender -->|implements| AnimationTarget

    style AnimationCore fill:#e3f2fd
    style Interpolation fill:#e8f5e9
    style EasingFunctions fill:#fff3e0
    style AnimationPlayback fill:#f3e5f5
    style Integration fill:#fce4ec

