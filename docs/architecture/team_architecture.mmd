graph TB
    subgraph TeamCore["Team Core"]
        TeamDefinition["TeamDefinition (Record)<br/>- token: String<br/>- translationKey: MutableComponent<br/>- color: TeamColor<br/>- flags: Map<TeamFlag, Boolean><br/>- playerLimit: int<br/>+ toIdentifier(): Identifier"]

        TeamColor["TeamColor (Enum)<br/>RED, BLUE, GREEN, YELLOW<br/>PINK, PURPLE, CYAN<br/>LIGHT_GRAY, GRAY, BLACK"]

        TeamFlag["TeamFlag (Enum)<br/>ALLOW_FRIENDLY_FIRE<br/>SHOW_TEAM_PREFIX<br/>SHOW_DEATH_MESSAGE<br/>SHOW_NAMEPLATE"]

        TeamManager["TeamManager (Singleton)<br/>- teams: Map<Identifier, TeamDefinition><br/>+ register(TeamDefinition)<br/>+ unregister(Identifier)<br/>+ all(): Collection<TeamDefinition><br/>+ getTeam(Identifier): Optional<br/>+ validate(TeamDefinition): boolean"]
    end

    subgraph TeamAdmin["Team Administration"]
        TeamAdminService["TeamAdminService<br/>+ createTeam(token, definition)<br/>+ modifyTeam(teamId, definition)<br/>+ deleteTeam(teamId)<br/>+ listTeams()"]
    end

    subgraph TeamStorage["Team Storage"]
        TeamStorageInterface["TeamStorage (Interface)<br/>+ save(Identifier, TeamDefinition)<br/>+ load(Identifier): TeamDefinition<br/>+ delete(Identifier)<br/>+ listAll(): Collection"]

        TeamStorageImpl["TeamStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize"]
    end

    subgraph Integration["System Integration"]
        GameConfig["GameConfig<br/>+ teams(): Map<String, Identifier><br/>+ teamDefinitions(): List<TeamDefinition>"]

        GameData["GameData<br/>- teamMembers: Map<Identifier, Set<UUID>><br/>+ movePlayerToTeam()<br/>+ teamOf(UUID)<br/>+ membersOf(Identifier)"]

        PermissionManager["PermissionManager<br/>- teamPermissions<br/>+ checkTeamPermission()"]

        AccessCommandService["AccessCommandService<br/>+ createTeamCommand<br/>+ modifyTeamCommand<br/>+ deleteTeamCommand"]

        RoleGroupSystem["RoleGroup System<br/>+ role-based team access"]
    end

    %% Core relationships
    TeamDefinition -->|defines color| TeamColor
    TeamDefinition -->|defines flags| TeamFlag
    TeamManager -->|manages| TeamDefinition
    TeamAdminService -->|uses| TeamManager
    TeamManager -->|persists via| TeamStorageInterface

    %% Storage
    TeamStorageInterface -->|implemented by| TeamStorageImpl

    %% Integration
    GameConfig -->|references| TeamDefinition
    GameData -->|uses| TeamDefinition
    GameData -->|manages| TeamDefinition
    TeamAdminService -->|manages| TeamDefinition
    PermissionManager -->|controls access to| TeamAdminService
    AccessCommandService -->|invokes| TeamAdminService
    RoleGroupSystem -->|integrates with| TeamDefinition

    %% External references
    TeamDefinition -.->|used by| GameInstance
    TeamManager -->|notifies| GameEventBus

    style TeamCore fill:#ffccbc
    style TeamAdmin fill:#fff9c4
    style TeamStorage fill:#b2dfdb
    style Integration fill:#e0e2f6

