graph TB
    subgraph BehaviorCore["Behavior Core System"]
        IObjectBeh["IObjectBeh<T extends BaseObjRt><br/>+ onInitialize(T object, GameInstance)<br/>+ onDestroy(T object, GameInstance)"]

        IBlockBeh["IBlockBeh<br/>extends IObjectBeh<BlockObjRt><br/>- implemented by block behaviors"]

        IEntityBeh["IEntityBeh<br/>extends IObjectBeh<EntityObjRt><br/>- implemented by entity behaviors"]
    end

    subgraph BlockBehaviors["Block Behaviors"]
        InteractableBeh["InteractableBeh implements IBlockBeh<br/>- EventListener<BlockInteractEvent><br/>- lastInteractTime: Map<UUID, Long><br/>+ onInitialize: subscribe to event<br/>+ onDestroy: unsubscribe from event<br/>- cooldown tracking<br/>- dispatch ObjectInteractEvent"]

        MineableBeh["MineableBeh implements IBlockBeh<br/>- EventListener<BlockBreakEvent><br/>+ onInitialize: subscribe to event<br/>+ onDestroy: unsubscribe<br/>- listen for block break<br/>- dispatch ObjectMineEvent"]
    end

    subgraph EntityBehaviors["Entity Behaviors"]
        AttackableBeh["AttackableBeh implements IEntityBeh<br/>- damageListener: EventListener<EntityDamageEvent><br/>- deathListener: EventListener<EntityDeathEvent><br/>+ onInitialize: subscribe to events<br/>+ onDestroy: unsubscribe<br/>- match victim UUID<br/>- dispatch ObjectDamageEvent<br/>- dispatch ObjectDeathEvent"]
    end

    subgraph BehaviorLifecycle["Behavior Lifecycle"]
        BehaviorAddition["Behavior Addition<br/>+ addBehavior(IBehavior)<br/>+ stored in runtime list<br/>+ called after construction"]

        OnInitialize["onInitialize(Runtime, GameInstance)<br/>+ register event listeners<br/>+ setup runtime state<br/>+ called when game starts"]

        OnDestroy["onDestroy(Runtime, GameInstance)<br/>+ unregister listeners<br/>+ cleanup resources<br/>+ called on removal"]
    end

    subgraph EventIntegration["Event Integration"]
        BlockEvents["Block Events<br/>- BlockBreakEvent<br/>- BlockInteractEvent<br/>- fired by Minecraft mixin"]

        EntityEvents["Entity Events<br/>- EntityDamageEvent<br/>- EntityDeathEvent<br/>- fired by game system"]

        ObjectEvents["Object Events<br/>- ObjectMineEvent<br/>- ObjectInteractEvent<br/>- ObjectDamageEvent<br/>- ObjectDeathEvent<br/>- dispatched by behaviors"]

        EventBus["ServerEventBus<br/>- subscribe(Class, EventListener)<br/>- dispatch(Event)"]
    end

    subgraph BehaviorPattern["Behavior Pattern"]
        EventListener["EventListener<E><br/>+ onEvent(E): ProcessResult"]

        ProcessResult["ProcessResult<br/>PASS - event continues<br/>CONSUME - event handled"]

        ListenerRegistration["Registration<br/>+ behavior implements IObjectBeh<br/>+ IObjectBeh extends IObjectBeh<Type><br/>+ castable to EventListener"]
    end

    subgraph RuntimeBehaviorBinding["Runtime Behavior Binding"]
        BlockObjRtBinding["BlockObjRt<br/>- behaviors: List<IBlockBeh><br/>+ calls in onInitialize<br/>+ calls in onDestroy"]

        EntityObjRtBinding["EntityObjRt<br/>- behaviors: List<IEntityBeh><br/>+ calls in onInitialize<br/>+ calls in onDestroy"]

        InteractableRtBinding["InteractableObjRt<br/>+ addBehavior(new InteractableBeh())<br/>+ in constructor"]

        MineableRtBinding["MineableObjRt<br/>+ behavior: MineableBeh<br/>+ field initialized<br/>+ called in lifecycle"]

        AttackableRtBinding["AttackableObjRt<br/>+ addBehavior(new AttackableBeh())<br/>+ in constructor"]
    end

    subgraph EventFlow["Event Flow"]
        MinecraftEvent["Minecraft Event<br/>BlockBreak, EntityDamage<br/>Player Action"]

        MyulibEvent["MyuLib Interceptor<br/>fires MyuLib Event<br/>BlockBreakEvent, EntityDamageEvent"]

        BehaviorListener["Behavior Listener<br/>receives event<br/>validates conditions<br/>filters by object"]

        ObjectEvent["Object Event<br/>ObjectMineEvent<br/>ObjectDamageEvent<br/>dispatched to bus"]

        GameLogic["Game Logic<br/>receives object event<br/>game state update"]
    end

    %% Core relationships
    IObjectBeh -->|extends to| IBlockBeh
    IObjectBeh -->|extends to| IEntityBeh
    IBlockBeh -->|implemented by| InteractableBeh
    IBlockBeh -->|implemented by| MineableBeh
    IEntityBeh -->|implemented by| AttackableBeh

    %% Lifecycle
    BehaviorAddition -->|calls| OnInitialize
    OnInitialize -->|leads to| OnDestroy
    BehaviorLifecycle -->|managed by| RuntimeBehaviorBinding

    %% Event integration
    BlockEvents -->|monitored by| InteractableBeh
    BlockEvents -->|monitored by| MineableBeh
    EntityEvents -->|monitored by| AttackableBeh
    InteractableBeh -->|dispatch| ObjectEvents
    MineableBeh -->|dispatch| ObjectEvents
    AttackableBeh -->|dispatch| ObjectEvents
    ObjectEvents -->|sent to| EventBus

    %% Behavior pattern
    IObjectBeh -->|extends| EventListener
    EventListener -->|returns| ProcessResult
    IObjectBeh -->|follows| ListenerRegistration

    %% Runtime binding
    BlockObjRtBinding -->|contains| InteractableBeh
    BlockObjRtBinding -->|contains| MineableBeh
    EntityObjRtBinding -->|contains| AttackableBeh
    InteractableRtBinding -->|uses| InteractableBeh
    MineableRtBinding -->|uses| MineableBeh
    AttackableRtBinding -->|uses| AttackableBeh

    %% Event flow
    MinecraftEvent -->|intercepted| MyulibEvent
    MyulibEvent -->|received by| BehaviorListener
    BehaviorListener -->|creates| ObjectEvent
    ObjectEvent -->|processed| GameLogic

