graph TB
    subgraph IObjectDef["IObjectDef (Interface)"]
        IObjectDef_def["+ token(): String<br/>+ getKind(): ObjectKind<br/>+ toIdentifier(): Identifier<br/>+ validate(): boolean<br/>+ createRuntimeInstance()"]
    end

    subgraph BaseObjDef["BaseObjDef (Abstract)"]
        BaseObjDef_def["- token: String<br/>- kind: ObjectKind<br/>- registry: Map<String, Property><br/>- values: Map<Property, Object><br/>+ get/set Property<br/>+ getProperties()<br/>+ getKind()"]
    end

    subgraph BlockObjDef["BlockObjDef (Abstract)"]
        BlockObjDef_def["+ BLOCK_STATE: Property<BlockState><br/>+ BOUNDING_BOX: Property<AABB><br/>+ registerProperties()"]
    end

    subgraph EntityObjDef["EntityObjDef (Abstract)"]
        EntityObjDef_def["+ entityType: EntityType<br/>+ getEntityType()"]
    end

    subgraph ConcreteDefinitions["Concrete Definition Classes"]
        MineableObjDef["MineableObjDef<br/>+ REWARD_EXP"]
        InteractableObjDef["InteractableObjDef<br/>+ COOLDOWN_MS"]
        AttackableObjDef["AttackableObjDef"]
        DecorativeObjDef["DecorativeObjDef<br/>+ NBT_DATA"]
        ProximityTriggerObjDef["ProximityTriggerObjDef<br/>+ RADIUS, SHAPE, TARGET"]
        RespawnPointObjDef["RespawnPointObjDef<br/>+ TEAM_ID"]
    end

    subgraph IObjectRt["IObjectRt (Interface)"]
        IObjectRt_def["+ getToken(): String<br/>+ getKind(): ObjectKind<br/>+ getProperties(): Collection<br/>+ getPosition(): Vec3<br/>+ setPosition(Vec3)<br/>+ spawn(), destroy()<br/>+ copy()"]
    end

    subgraph BaseObjRt["BaseObjRt<D> (Abstract)"]
        BaseObjRt_def["- definition: D<br/>- state: ObjectState<br/>+ get/set Property<br/>+ onSpawn/onDestroy<br/>+ spawn(), destroy()"]
    end

    subgraph BlockObjRt["BlockObjRt<D> (Abstract)"]
        BlockObjRt_def["- behaviors: List<IBlockBeh><br/>- originalState: BlockState<br/>+ addBehavior/removeBehavior<br/>+ onInitialize, onSpawn, onDestroy"]
    end

    subgraph EntityObjRt["EntityObjRt<D,E> (Abstract)"]
        EntityObjRt_def["- entity: E<br/>- behaviors: List<IEntityBeh><br/>+ addBehavior/removeBehavior<br/>+ summon/createEntity<br/>+ getEntity()"]
    end

    subgraph ConcreteRuntime["Concrete Runtime Classes"]
        MineableObjRt["MineableObjRt<br/>+ behavior: MineableBeh"]
        InteractableObjRt["InteractableObjRt<br/>+ behavior: InteractableBeh"]
        AttackableObjRt["AttackableObjRt<br/>+ behavior: AttackableBeh"]
        DecorativeObjRt["DecorativeObjRt"]
        ProximityTriggerObjRt["ProximityTriggerObjRt"]
        RespawnPointObjRt["RespawnPointObjRt"]
    end

    subgraph Behavior["Behavior System"]
        IObjectBeh["IObjectBeh<T><br/>+ onInitialize(T, GameInstance)<br/>+ onDestroy(T, GameInstance)"]
        IBlockBeh["IBlockBeh<br/>extends IObjectBeh<BlockObjRt>"]
        IEntityBeh["IEntityBeh<br/>extends IObjectBeh<EntityObjRt>"]
        InteractableBeh["InteractableBeh<br/>implements IBlockBeh"]
        MineableBeh["MineableBeh<br/>implements IBlockBeh"]
        AttackableBeh["AttackableBeh<br/>implements IEntityBeh"]
    end

    subgraph Events["Event System"]
        BlockBreakEvent["BlockBreakEvent"]
        BlockInteractEvent["BlockInteractEvent"]
        EntityDamageEvent["EntityDamageEvent"]
        EntityDeathEvent["EntityDeathEvent"]
        EntityInteractEvent["EntityInteractEvent"]
        ObjectMineEvent["ObjectMineEvent"]
        ObjectInteractEvent["ObjectInteractEvent"]
        ObjectDamageEvent["ObjectDamageEvent"]
        ObjectDeathEvent["ObjectDeathEvent"]
        StateChangeEvent["StateChangeEvent"]
    end

    subgraph Support["Support Classes"]
        ObjectKind["ObjectKind<br/>ATTACKABLE, MINEABLE, etc."]
        ObjectState["ObjectState<br/>NOT_LOADED, SPAWNED, DESTROYED"]
        ObjectManager["ObjectManager"]
    end

    %% Definition hierarchy
    IObjectDef --> BaseObjDef
    BaseObjDef --> BlockObjDef
    BaseObjDef --> EntityObjDef
    BlockObjDef --> MineableObjDef
    BlockObjDef --> InteractableObjDef
    EntityObjDef --> AttackableObjDef
    EntityObjDef --> DecorativeObjDef
    BaseObjDef --> ProximityTriggerObjDef
    BaseObjDef --> RespawnPointObjDef

    %% Runtime hierarchy
    IObjectRt --> BaseObjRt
    BaseObjRt --> BlockObjRt
    BaseObjRt --> EntityObjRt
    BlockObjRt --> MineableObjRt
    BlockObjRt --> InteractableObjRt
    EntityObjRt --> AttackableObjRt
    EntityObjRt --> DecorativeObjRt
    BaseObjRt --> ProximityTriggerObjRt
    BaseObjRt --> RespawnPointObjRt

    %% Definition to Runtime relationship
    MineableObjDef -->|createRuntimeInstance| MineableObjRt
    InteractableObjDef -->|createRuntimeInstance| InteractableObjRt
    AttackableObjDef -->|createRuntimeInstance| AttackableObjRt
    DecorativeObjDef -->|createRuntimeInstance| DecorativeObjRt
    ProximityTriggerObjDef -->|createRuntimeInstance| ProximityTriggerObjRt
    RespawnPointObjDef -->|createRuntimeInstance| RespawnPointObjRt

    %% Behavior relationships
    IObjectBeh --> IBlockBeh
    IObjectBeh --> IEntityBeh
    IBlockBeh --> InteractableBeh
    IBlockBeh --> MineableBeh
    IEntityBeh --> AttackableBeh
    InteractableBeh -->|attached to| InteractableObjRt
    MineableBeh -->|attached to| MineableObjRt
    AttackableBeh -->|attached to| AttackableObjRt

    %% Event relationships
    InteractableObjRt -->|dispatch| ObjectInteractEvent
    MineableObjRt -->|dispatch| ObjectMineEvent
    AttackableObjRt -->|dispatch| ObjectDamageEvent
    AttackableObjRt -->|dispatch| ObjectDeathEvent

    %% Support relationships
    BaseObjDef -.->|uses| ObjectKind
    BaseObjRt -.->|uses| ObjectState
    ObjectManager -->|manages| BaseObjDef

    style IObjectDef fill:#e1f5ff
    style IObjectRt fill:#e1f5ff
    style BaseObjDef fill:#fff3e0
    style BaseObjRt fill:#fff3e0
    style Behavior fill:#f3e5f5
    style Events fill:#e8f5e9
    style Support fill:#fce4ec

