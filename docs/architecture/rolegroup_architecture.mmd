graph TB
    subgraph RoleGroupCore["RoleGroup Core"]
        RoleGroupDefinition["RoleGroupDefinition (Record)<br/>- token: String<br/>- translationKey: MutableComponent<br/>- priority: int<br/>- metadata: Map<String, String><br/>- members: Set<UUID><br/>+ toIdentifier(): Identifier"]

        RoleGroupManager["RoleGroupManager (Singleton)<br/>- groups: Map<Identifier, RoleGroupDefinition><br/>+ register(RoleGroupDefinition)<br/>+ unregister(Identifier)<br/>+ all(): Collection<br/>+ getGroup(Identifier): Optional<br/>+ validate(RoleGroupDefinition): boolean"]
    end

    subgraph RoleGroupMembership["Membership Management"]
        MembershipManager["MembershipManager<br/>+ addMember(UUID, Identifier)<br/>+ removeMember(UUID, Identifier)<br/>+ isMember(UUID, Identifier): boolean<br/>+ getMemberships(UUID): Set<Identifier>"]

        GroupHierarchy["Group Hierarchy<br/>- parentGroups: Map<Identifier, Set<Identifier>><br/>- childGroups: Map<Identifier, Set<Identifier>><br/>+ getInheritedPermissions()"]
    end

    subgraph RoleGroupStorage["RoleGroup Storage"]
        RoleGroupStorageInterface["RoleGroupStorage (Interface)<br/>+ save(Identifier, RoleGroupDefinition)<br/>+ load(Identifier): RoleGroupDefinition<br/>+ delete(Identifier)<br/>+ listAll(): Collection"]

        RoleGroupStorageImpl["RoleGroupStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize<br/>- membership persistence"]

        RoleGroupStorage["RoleGroupStorage (Dedicated)<br/>+ saveGroup(Identifier, RoleGroupDefinition)<br/>+ loadGroup(Identifier)<br/>+ saveMembership(UUID, Identifier)<br/>+ loadMembership(UUID)"]
    end

    subgraph Integration["System Integration"]
        GameConfig["GameConfig<br/>+ roleGroupDefinitions(): List<RoleGroupDefinition>"]

        GameData["GameData<br/>- registeredRoleGroupIds: Set<Identifier><br/>+ onInit: register role groups"]

        PermissionManager["PermissionManager<br/>+ grants group-based permissions<br/>+ inherits from parent groups"]

        AccessCommandService["AccessCommandService<br/>+ createRoleGroupCommand<br/>+ modifyRoleGroupCommand<br/>+ deleteRoleGroupCommand<br/>+ addMemberCommand<br/>+ removeMemberCommand"]

        CommandContext["CommandContext<br/>+ userRole: Identifier<br/>+ checkGroupPermission()"]

        TeamManager["TeamManager<br/>+ associate role groups with teams"]
    end

    subgraph DefaultGroups["Default Groups"]
        AdminGroup["Admin Group<br/>- ALL permissions<br/>- created at startup"]

        ModGroup["Mod Group<br/>- Limited admin permissions<br/>- optional"]

        PlayerGroup["Player Group<br/>- View-only permissions<br/>- automatic for all players"]

        EveryoneGroup["Everyone Group<br/>- Common permissions<br/>- automatic membership"]
    end

    %% Core relationships
    RoleGroupManager -->|manages| RoleGroupDefinition
    RoleGroupManager -->|persists via| RoleGroupStorageInterface
    RoleGroupStorageInterface -->|implemented by| RoleGroupStorageImpl

    %% Membership
    RoleGroupDefinition -->|contains| MembershipManager
    MembershipManager -->|manages| RoleGroupManager
    GroupHierarchy -->|organizes| RoleGroupDefinition

    %% Storage
    RoleGroupStorage -->|manages| RoleGroupStorageImpl
    RoleGroupStorageImpl -->|persists| MembershipManager

    %% Integration
    GameConfig -->|contains| RoleGroupDefinition
    GameData -->|initializes| RoleGroupManager
    PermissionManager -->|grants via| RoleGroupDefinition
    AccessCommandService -->|manages| RoleGroupManager
    CommandContext -->|checks| RoleGroupDefinition
    TeamManager -->|integrates with| RoleGroupDefinition
    MembershipManager -->|tracks| CommandContext

    %% Default groups
    RoleGroupManager -->|creates| AdminGroup
    RoleGroupManager -->|creates| ModGroup
    RoleGroupManager -->|creates| PlayerGroup
    RoleGroupManager -->|creates| EveryoneGroup

    %% Permissions
    AdminGroup -->|grants| PermissionManager
    ModGroup -->|grants| PermissionManager
    PlayerGroup -->|grants| PermissionManager
    EveryoneGroup -->|grants| PermissionManager

    %% Event flow
    RoleGroupManager -->|notifies| GameEventBus
    MembershipManager -->|triggers event on change| ServerEventBus

    style RoleGroupCore fill:#e1f5fe
    style RoleGroupMembership fill:#e8f5e9
    style RoleGroupStorage fill:#f3e5f5
    style Integration fill:#fff3e0
    style DefaultGroups fill:#fce4ec

