graph TB
    subgraph FieldCore["Field Core"]
        FieldDefinition["FieldDefinition (Record)<br/>- token: String<br/>- dimensionId: Identifier<br/>- bounds: AABB<br/>- fieldData: Map<String, Object><br/>+ toIdentifier(): Identifier"]

        FieldManager["FieldManager (Singleton)<br/>- fields: Map<Identifier, FieldDefinition><br/>+ register(FieldDefinition)<br/>+ unregister(Identifier)<br/>+ all(): Map<Identifier, FieldDefinition><br/>+ getField(Identifier): Optional<br/>+ validate(FieldDefinition): boolean"]
    end

    subgraph FieldVisualization["Field Visualization"]
        FieldVisualizationManager["FieldVisualizationManager<br/>+ visualize(FieldDefinition, Player)<br/>+ hideVisualization(Player)<br/>- cachedParticles: Map<Player, List>"]

        VisualizationMode["VisualizationMode (Enum)<br/>OUTLINE, FILL, WIREFRAME"]
    end

    subgraph FieldNetwork["Field Networking"]
        FieldNetworkPacket["FieldNetworkPacket<br/>+ fieldId: Identifier<br/>+ action: NetworkAction<br/>+ bounds: AABB"]

        FieldNetworkHandler["FieldNetworkHandler<br/>+ sendFieldUpdate(Player, FieldDefinition)<br/>+ sendFieldRemove(Player, Identifier)"]
    end

    subgraph FieldStorage["Field Storage"]
        FieldStorageInterface["FieldStorage (Interface)<br/>+ save(Identifier, FieldDefinition)<br/>+ load(Identifier): FieldDefinition<br/>+ delete(Identifier)<br/>+ listAll(): Collection"]

        FieldStorageImpl["FieldStorage (Impl)<br/>- storageDir: File<br/>+ serialize/deserialize<br/>+ validate bounds"]
    end

    subgraph Integration["System Integration"]
        GameConfig["GameConfig<br/>+ fieldDefinitions(): List<FieldDefinition>"]

        GameData["GameData<br/>- registeredFieldIds: Set<Identifier><br/>+ onInit: register fields<br/>+ onReset: unregister fields"]

        PermissionManager["PermissionManager<br/>+ MANAGE_FIELDS<br/>+ VIEW_FIELDS"]

        AccessCommandService["AccessCommandService<br/>+ createFieldCommand<br/>+ modifyFieldCommand<br/>+ deleteFieldCommand<br/>+ listFieldsCommand"]

        CommandContext["CommandContext<br/>+ currentFieldId: Identifier"]
    end

    %% Core relationships
    FieldManager -->|manages| FieldDefinition
    FieldManager -->|persists via| FieldStorageInterface
    FieldStorageInterface -->|implemented by| FieldStorageImpl

    %% Visualization
    FieldVisualizationManager -->|visualizes| FieldDefinition
    FieldVisualizationManager -->|uses| VisualizationMode
    FieldVisualizationManager -->|sends data via| FieldNetworkHandler
    FieldNetworkHandler -->|sends| FieldNetworkPacket

    %% Integration
    GameConfig -->|contains| FieldDefinition
    GameData -->|registers/unregisters| FieldManager
    PermissionManager -->|controls| AccessCommandService
    AccessCommandService -->|manages| FieldManager
    FieldManager -->|notifies| FieldNetworkHandler
    CommandContext -->|references| FieldManager

    %% Relationships
    FieldDefinition -.->|defines region in| Dimension
    FieldDefinition -.->|bounds: AABB| World

    style FieldCore fill:#c8e6c9
    style FieldVisualization fill:#bbdefb
    style FieldNetwork fill:#f8bbd0
    style FieldStorage fill:#ffe0b2
    style Integration fill:#e0e2f6

