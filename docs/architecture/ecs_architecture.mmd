graph TB
    subgraph ECSCore["ECS Core"]
        Entity["Entity (int ID)<br/>+ sparse set storage<br/>+ component bitmask"]

        Component["Component (Interface)<br/>+ lifecycle hooks<br/>+ type identifier"]

        EcsContainer["EcsContainer<br/>- entities: SparseSet<int><br/>- components: Map<Class, ComponentStorage><br/>+ createEntity(): int<br/>+ deleteEntity(int)<br/>+ addComponent(int, Component)<br/>+ getComponent(int, Class): Component<br/>+ removeComponent(int, Class)<br/>+ query(ComponentMask): List<int>"]

        ComponentStorage["ComponentStorage<br/>- dense: List<Component><br/>- sparse: Map<int, int><br/>+ add(int, Component)<br/>+ get(int): Component<br/>+ remove(int)<br/>+ iterate(): Iterable"]
    end

    subgraph ComponentTypes["Component Types"]
        TransformComponent["TransformComponent<br/>- position: Vec3<br/>- rotation: Quaternion<br/>- scale: Vec3"]

        RenderComponent["RenderComponent<br/>- model: Model<br/>- visible: boolean<br/>- layer: int"]

        PhysicsComponent["PhysicsComponent<br/>- velocity: Vec3<br/>- acceleration: Vec3<br/>- mass: float"]

        AnimatorComponent["AnimatorComponent<br/>- animations: Map<String, AnimationSpec><br/>- currentAnimation: String<br/>- playback: PlaybackState"]

        BehaviorComponent["BehaviorComponent<br/>- behaviors: List<IBehavior><br/>+ update(deltaTime)"]

        CustomComponents["Custom Components<br/>+ user-defined types<br/>+ flexible data storage"]
    end

    subgraph Lifecycle["Component Lifecycle"]
        LifecycleInterface["IComponentLifecycle<br/>+ onCreate(int, EcsContainer)<br/>+ onEnable()<br/>+ onDisable()<br/>+ onDestroy()"]

        OnCreat["onCreate<br/>- initialization<br/>- resource loading"]

        OnEnable["onEnable<br/>- activation<br/>- event registration"]

        OnDisable["onDisable<br/>- deactivation<br/>- event unsubscription"]

        OnDestroy["onDestroy<br/>- cleanup<br/>- resource release"]
    end

    subgraph Querying["Component Querying"]
        Query["Query<br/>- components: Set<Class><br/>- excludes: Set<Class><br/>+ execute(): List<int><br/>+ forEach(Consumer)"]

        QueryBuilder["QueryBuilder<br/>+ with(Class)<br/>+ without(Class)<br/>+ build(): Query"]

        Iterator["ComponentIterator<br/>- entities: List<int><br/>- components: Map<int, Component><br/>+ hasNext(): boolean<br/>+ next(): int"]
    end

    subgraph Storage["Storage Management"]
        SparseSet["SparseSet<T><br/>- dense: List<T><br/>- sparse: Map<int, int><br/>+ add(int, T)<br/>+ remove(int)<br/>+ get(int): T<br/>+ contains(int): boolean"]

        DensePacking["Dense Packing<br/>- memory efficiency<br/>- cache friendly<br/>- iteration speed"]
    end

    subgraph Integration["System Integration"]
        GameData["GameData<br/>- ecsContainer: EcsContainer<br/>+ entityManager<br/>+ componentQuery()"]

        GameInstance["GameInstance<br/>+ getEcsContainer(): EcsContainer<br/>+ createEntity(): int<br/>+ addComponent(int, Component)"]

        AnimationSystem["Animation System<br/>+ updates AnimatorComponent<br/>+ manages playback state"]

        EventSystem["Event System<br/>+ entity lifecycle events<br/>+ component added/removed events"]

        GameLogic["Game Logic<br/>- entity queries<br/>- component iteration<br/>- system updates"]
    end

    %% Core relationships
    EcsContainer -->|manages| Entity
    EcsContainer -->|stores| ComponentStorage
    ComponentStorage -->|contains| Component
    Component -->|implements| LifecycleInterface
    EcsContainer -->|performs| Query
    Query -->|uses| QueryBuilder
    Query -->|iterates with| Iterator

    %% Component types
    TransformComponent -.->|implements| Component
    RenderComponent -.->|implements| Component
    PhysicsComponent -.->|implements| Component
    AnimatorComponent -.->|implements| Component
    BehaviorComponent -.->|implements| Component
    CustomComponents -.->|implements| Component

    %% Lifecycle
    Component -->|defines| LifecycleInterface
    LifecycleInterface -->|onCreate| OnCreat
    LifecycleInterface -->|onEnable| OnEnable
    LifecycleInterface -->|onDisable| OnDisable
    LifecycleInterface -->|onDestroy| OnDestroy

    %% Storage
    ComponentStorage -->|uses| SparseSet
    SparseSet -->|provides| DensePacking

    %% Integration
    GameData -->|contains| EcsContainer
    GameInstance -->|accesses| EcsContainer
    AnimationSystem -->|queries| AnimatorComponent
    EventSystem -->|listens to| LifecycleInterface
    GameLogic -->|queries| Query
    GameLogic -->|iterates| ComponentIterator

    %% Data flow
    GameInstance -->|tick| GameLogic
    GameLogic -->|query| EcsContainer
    EcsContainer -->|execute query| Query
    Query -->|returns entities| Iterator

