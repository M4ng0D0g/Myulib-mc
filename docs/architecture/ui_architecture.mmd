graph TB
    subgraph UIBridge["UI Bridge System"]
        ConfigurationUiBridge["ConfigurationUiBridge (Interface)<br/>+ openSettings(Player)<br/>+ openGameConfig(Player)<br/>+ openTeamConfig(Player)<br/>+ closeSettings(Player)"]

        NoopConfigurationUiBridge["NoopConfigurationUiBridge<br/>- no-op implementation<br/>- for disabled UIs"]

        ConfigurationUiRegistry["ConfigurationUiRegistry (Singleton)<br/>- bridge: ConfigurationUiBridge<br/>+ setBridge(ConfigurationUiBridge)<br/>+ getBridge(): ConfigurationUiBridge"]
    end

    subgraph SidebarUI["Sidebar UI"]
        SidebarComponent["SidebarComponent<br/>- title: String<br/>- items: List<SidebarItem><br/>- position: Anchor"]

        SidebarItem["SidebarItem<br/>- label: String<br/>- icon: ItemStack<br/>- action: Consumer<Player>"]

        SidebarManager["SidebarManager<br/>- sidebars: Map<Player, SidebarComponent><br/>+ createSidebar(Player, String)<br/>+ addItem(Player, SidebarItem)<br/>+ removeItem(Player, int)<br/>+ destroy(Player)"]
    end

    subgraph TablistUI["Tablist UI"]
        TablistComponent["TablistComponent<br/>- header: String<br/>- footer: String<br/>- entries: List<TablistEntry>"]

        TablistEntry["TablistEntry<br/>- name: String<br/>- skin: UUID<br/>- ping: int<br/>- displayName: String"]

        TablistManager["TablistManager<br/>- tablists: Map<Player, TablistComponent><br/>+ createTablist(Player)<br/>+ updateEntry(Player, String, TablistEntry)<br/>+ updateHeader(Player, String)<br/>+ updateFooter(Player, String)"]
    end

    subgraph NetworkSync["Network Synchronization"]
        UINetworkPacket["UINetworkPacket<br/>+ type: PacketType<br/>+ data: byte[]<br/>+ version: int"]

        UINetworkHandler["UINetworkHandler<br/>+ sendSidebarCreate(Player, SidebarComponent)<br/>+ sendSidebarUpdate(Player, int, SidebarItem)<br/>+ sendTablistUpdate(Player, TablistEntry)<br/>+ sendPacket(Player, UINetworkPacket)"]

        ClientUIHandler["ClientUIHandler<br/>- renders UI elements<br/>- handles user input<br/>- sends events back"]
    end

    subgraph UIAnimation["UI Animation"]
        UIAnimationTarget["UIAnimationTarget (Animation)<br/>+ position, size, color<br/>+ opacity, rotation"]

        TransitionEffect["TransitionEffect<br/>- fadeIn, slideIn<br/>- expand, collapse"]

        AnimatedUIComponent["AnimatedUIComponent<br/>- animationSpec: AnimationSpec<br/>- playback: PlaybackState<br/>+ animate(String, AnimationSpec)"]
    end

    subgraph Integration["System Integration"]
        GameUI["Game UI<br/>- team info display<br/>- player stats<br/>- game status"]

        CommandNotifications["Command Notifications<br/>- command results<br/>- action logs"]

        PermissionUI["Permission UI<br/>- permission settings<br/>- role management"]

        ConfigUI["Configuration UI<br/>- game config<br/>- field settings<br/>- team management"]
    end

    %% Bridge relationships
    ConfigurationUiBridge -->|defines interface| ConfigurationUiRegistry
    NoopConfigurationUiBridge -->|implements| ConfigurationUiBridge
    ConfigurationUiRegistry -->|manages| ConfigurationUiBridge

    %% Sidebar relationships
    SidebarComponent -->|contains| SidebarItem
    SidebarManager -->|manages| SidebarComponent
    SidebarItem -->|action| SidebarManager

    %% Tablist relationships
    TablistComponent -->|contains| TablistEntry
    TablistManager -->|manages| TablistComponent

    %% Network relationships
    UINetworkHandler -->|sends| UINetworkPacket
    SidebarManager -->|updates via| UINetworkHandler
    TablistManager -->|updates via| UINetworkHandler
    ClientUIHandler -->|receives| UINetworkPacket

    %% Animation relationships
    AnimatedUIComponent -->|applies| UIAnimationTarget
    TransitionEffect -->|uses| UIAnimationTarget
    AnimatedUIComponent -->|plays| UIAnimationTarget

    %% Integration
    GameUI -->|uses| SidebarManager
    GameUI -->|uses| TablistManager
    CommandNotifications -->|displays in| SidebarComponent
    PermissionUI -->|configured via| ConfigurationUiBridge
    ConfigUI -->|configured via| ConfigurationUiBridge

    %% Event flow
    ClientUIHandler -->|broadcasts| UIEvent
    UIEvent -->|triggers| GameLogic

    style UIBridge fill:#e3f2fd
    style SidebarUI fill:#e8f5e9
    style TablistUI fill:#fff3e0
    style NetworkSync fill:#f3e5f5
    style UIAnimation fill:#fce4ec
    style Integration fill:#f1f8e9

